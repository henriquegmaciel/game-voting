@model SiteSettingsViewModel

@{
    ViewData["Title"] = "Configurações";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <h4 class="mb-1">Configurações</h4>
                <p class="text-muted small mb-4">Defina quantos itens aparecem em cada lista.</p>

                @if (TempData["Sucesso"] is string sucesso)
                {
                    <div class="alert alert-success">@sucesso</div>
                }

                <form method="post">
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Lista principal</label>
                        <input asp-for="MainListSize" class="form-control" type="number" />
                        <span asp-validation-for="MainListSize" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Top mais votados</label>
                        <input asp-for="TopListSize" class="form-control" type="number" />
                        <span asp-validation-for="TopListSize" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Histórico de sessões</label>
                        <input asp-for="HistoryListSize" class="form-control" type="number" />
                        <span asp-validation-for="HistoryListSize" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Agendamentos</label>
                        <input asp-for="ScheduleListSize" class="form-control" type="number" />
                        <span asp-validation-for="ScheduleListSize" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Salvar</button>
                        <a asp-controller="Game" asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
